{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "attribution": {
    "commit": "",
    "pr": ""
  },

  "env": {
    "ENABLE_LSP_TOOL": "1"
  },

  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "pyright@claude-plugins-official": true
  },

  "statusLine": {
    "type": "command",
    "command": "$CLAUDE_PROJECT_DIR/.claude/statusline/statusline.sh",
    "padding": 0
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-dangerous-bash.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/protect-paths.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/audit-log.sh",
            "timeout": 3,
            "async": true
          }
        ]
      }
    ]
  }
}
